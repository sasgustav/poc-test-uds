NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cobranca_user
DB_PASSWORD=cobranca_pass
DB_DATABASE=cobranca_db
DB_POOL_MAX=20

# --- API ---
API_DEFAULT_VERSION=1
# Lista separada por vírgula. Use "*" só em dev.
CORS_ORIGINS=*

# --- AuthN stub ---
# sha256 hex de uma api key. Em produção: JWT/OAuth.
# Exemplo: printf "dev-key" | sha256sum
API_KEY_SHA256=8bb0cf6eb9b17d0f7d22b456f121257dc1254e1f01665370476383ea776df414

# --- Throttler ---
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=regua-cobrancas
OTEL_ENABLED=false

# --- Scheduler / régua ---
SCHEDULER_ENABLED=true
SCHEDULER_BATCH_SIZE=50
SCHEDULER_MAX_ATTEMPTS=5
DEFAULT_TIMEZONE=America/Sao_Paulo
REMINDER_HOUR=9
